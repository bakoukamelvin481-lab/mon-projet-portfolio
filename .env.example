# Configuration du Chatbot BFA
# ===================================

# 🔑 Clé API OpenAI (REMPLACE PAR LA TIENNE)
# Obtiens-la sur: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_API_KEY_HERE

# 🤖 Modèle OpenAI à utiliser
# Options: gpt-3.5-turbo, gpt-4, gpt-4-turbo
OPENAI_MODEL=gpt-3.5-turbo

# 📝 Température (créativité des réponses)
# 0 = réponses exactes/factuelles
# 0.5 = équilibré (recommandé)
# 1 = très créatif/varié
OPENAI_TEMPERATURE=0.7

# 📏 Nombre max de tokens par réponse
# Moins = plus rapide et moins coûteux
# Plus = réponses plus longues
OPENAI_MAX_TOKENS=500

# 🎨 Couleur du branding (hex)
BRAND_COLOR=#22c98a
SECONDARY_COLOR=#1d1d1f
ACCENT_COLOR=#1558d6

# 💾 Stockage des conversations
# local = sauvegarde en localStorage (côté client)
# server = envoie au serveur (recommandé)
STORAGE_TYPE=local

# 📧 Email de contact (affiché dans les erreurs)
CONTACT_EMAIL=support@brushforalways.com

# 🌐 URL du backend (si tu utilises un serveur)
# Vide = utilise l'API OpenAI directement
BACKEND_URL=

# ⏱️ Timeout API (ms)
API_TIMEOUT=30000

# 🔐 Environnement
# development = logs détaillés
# production = logs minimaux
ENVIRONMENT=development
