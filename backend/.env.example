# Backend Configuration pour ChatBot BFA

# 🔑 OpenAI API Key
# Obtiens-la sur: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_API_KEY_HERE

# 🤖 Modèle OpenAI
OPENAI_MODEL=gpt-3.5-turbo

# 📝 Température de créativité (0-1)
OPENAI_TEMPERATURE=0.7

# 📏 Nombre max de tokens par réponse
OPENAI_MAX_TOKENS=500

# ⏱️ Timeout API (ms)
API_TIMEOUT=30000

# 🌐 Port du serveur
PORT=3000

# 🔒 Domaines autorisés (CORS)
# Exemple: http://localhost:3000,https://brushforalways.com
ALLOWED_ORIGINS=*

# 📊 Environnement
NODE_ENV=development
